# Include README and LICENSE
include README.md
include LICENSE
include requirements.txt
include requirements-dev.txt

# Include package data
recursive-include anomaly_detection *.py

# Include documentation
recursive-include docs *.md *.rst *.txt
include aggressive_driving_analysis.md

# Include example Python scripts only (not data files)
include examples/*.py
include examples/*.md
include examples/*.ipynb
include examples/*.txt

# Exclude images and data directories completely from distribution
prune imgs
prune examples/original_format_data
prune examples/synthetic_driving_data

# Exclude large data files from package
global-exclude *.csv
global-exclude *.png
global-exclude *.jpg
global-exclude *.jpeg
global-exclude *.gif

# Exclude unnecessary files
global-exclude *.pyc
global-exclude *.pyo
global-exclude *.pyd
global-exclude __pycache__
global-exclude *.so
global-exclude .DS_Store
global-exclude .git*
global-exclude .vscode
global-exclude .idea
global-exclude *.egg-info
global-exclude dist
global-exclude build

# Exclude old rulsif directory at root
prune rulsif
# Exclude tests from package distribution
prune tests
